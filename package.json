{
  "name": "kanban-markdown",
  "displayName": "Kanban Markdown",
  "description": "A kanban board for your codebase. Features stored as markdown.",
  "version": "1.12.1",
  "publisher": "LachyFS",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LachyFS/kanban-markdown-vscode-extension"
  },
  "bugs": {
    "url": "https://github.com/LachyFS/kanban-markdown-vscode-extension/issues"
  },
  "homepage": "https://github.com/LachyFS/kanban-markdown-vscode-extension#readme",
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "kanban",
    "markdown",
    "project management",
    "task management",
    "board"
  ],
  "activationEvents": [
    "onWebviewPanel:kanban-markdown.panel",
    "onView:kanban-markdown.boardView"
  ],
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kanban-markdown",
          "title": "%viewContainer.title%",
          "icon": "resources/kanban.svg"
        }
      ]
    },
    "views": {
      "kanban-markdown": [
        {
          "id": "kanban-markdown.boardView",
          "name": "%view.board.name%",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "kanban-markdown.open",
        "title": "%command.open.title%",
        "category": "%command.category%",
        "icon": {
          "light": "resources/kanban-light.svg",
          "dark": "resources/kanban-dark.svg"
        }
      },
      {
        "command": "kanban-markdown.addFeature",
        "title": "%command.addFeature.title%",
        "category": "%command.category%"
      }
    ],
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "kanban-markdown.language": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "en",
            "es",
            "pt"
          ],
          "enumDescriptions": [
            "%config.language.auto%",
            "%config.language.en%",
            "%config.language.es%",
            "%config.language.pt%"
          ],
          "description": "%config.language.description%"
        },
        "kanban-markdown.featuresDirectory": {
          "type": "string",
          "default": ".devtool/features",
          "description": "%config.featuresDirectory.description%"
        },
        "kanban-markdown.filenamePattern": {
          "type": "string",
          "default": "name-date",
          "enum": [
            "name-date",
            "date-name",
            "name-datetime",
            "datetime-name"
          ],
          "enumDescriptions": [
            "%config.filenamePattern.nameDate%",
            "%config.filenamePattern.dateName%",
            "%config.filenamePattern.nameDatetime%",
            "%config.filenamePattern.datetimeName%"
          ],
          "description": "%config.filenamePattern.description%"
        },
        "kanban-markdown.defaultPriority": {
          "type": "string",
          "default": "medium",
          "enum": [
            "critical",
            "high",
            "medium",
            "low"
          ],
          "enumDescriptions": [
            "%config.defaultPriority.critical%",
            "%config.defaultPriority.high%",
            "%config.defaultPriority.medium%",
            "%config.defaultPriority.low%"
          ],
          "description": "%config.defaultPriority.description%"
        },
        "kanban-markdown.defaultStatus": {
          "type": "string",
          "default": "backlog",
          "enum": [
            "backlog",
            "todo",
            "in-progress",
            "review",
            "done"
          ],
          "enumDescriptions": [
            "%config.defaultStatus.backlog%",
            "%config.defaultStatus.todo%",
            "%config.defaultStatus.inProgress%",
            "%config.defaultStatus.review%",
            "%config.defaultStatus.done%"
          ],
          "description": "%config.defaultStatus.description%"
        },
        "kanban-markdown.columns": {
          "type": "array",
          "default": [
            {
              "id": "backlog",
              "name": "Backlog",
              "color": "#6b7280"
            },
            {
              "id": "todo",
              "name": "To Do",
              "color": "#3b82f6"
            },
            {
              "id": "in-progress",
              "name": "In Progress",
              "color": "#f59e0b"
            },
            {
              "id": "review",
              "name": "Review",
              "color": "#8b5cf6"
            },
            {
              "id": "done",
              "name": "Done",
              "color": "#22c55e"
            }
          ],
          "description": "%config.columns.description%",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "%config.columns.id.description%"
              },
              "name": {
                "type": "string",
                "description": "%config.columns.name.description%"
              },
              "color": {
                "type": "string",
                "description": "%config.columns.color.description%"
              }
            },
            "required": [
              "id",
              "name",
              "color"
            ]
          }
        },
        "kanban-markdown.aiAgent": {
          "type": "string",
          "default": "claude",
          "enum": [
            "claude",
            "codex",
            "copilot",
            "opencode"
          ],
          "enumDescriptions": [
            "%config.aiAgent.claude%",
            "%config.aiAgent.codex%",
            "%config.aiAgent.copilot%",
            "%config.aiAgent.opencode%"
          ],
          "description": "%config.aiAgent.description%"
        },
        "kanban-markdown.showPriorityBadges": {
          "type": "boolean",
          "default": true,
          "description": "%config.showPriorityBadges.description%"
        },
        "kanban-markdown.showAssignee": {
          "type": "boolean",
          "default": true,
          "description": "%config.showAssignee.description%"
        },
        "kanban-markdown.showDueDate": {
          "type": "boolean",
          "default": true,
          "description": "%config.showDueDate.description%"
        },
        "kanban-markdown.showLabels": {
          "type": "boolean",
          "default": true,
          "description": "%config.showLabels.description%"
        },
        "kanban-markdown.showBuildWithAI": {
          "type": "boolean",
          "default": true,
          "description": "%config.showBuildWithAI.description%"
        },
        "kanban-markdown.showFileName": {
          "type": "boolean",
          "default": false,
          "description": "%config.showFileName.description%"
        },
        "kanban-markdown.compactMode": {
          "type": "boolean",
          "default": false,
          "description": "%config.compactMode.description%"
        },
        "kanban-markdown.addNewCardsToTop": {
          "type": "boolean",
          "default": false,
          "description": "%config.addNewCardsToTop.description%"
        },
        "kanban-markdown.markdownEditorMode": {
          "type": "boolean",
          "default": false,
          "description": "%config.markdownEditorMode.description%"
        }
      }
    },
    "menus": {
      "editor/title/run": [
        {
          "command": "kanban-markdown.open",
          "when": "resourceLangId == markdown"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run build:extension && npm run build:webview",
    "build:extension": "esbuild src/extension/index.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "build:webview": "vite build",
    "watch": "concurrently \"npm run watch:extension\" \"npm run watch:webview\"",
    "watch:extension": "esbuild src/extension/index.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch",
    "watch:webview": "vite build --watch",
    "dev": "npm run watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.mts",
    "test:watch": "vitest --config vitest.config.mts",
    "test:coverage": "vitest run --config vitest.config.mts --coverage",
    "build:integration": "tsc --project tsconfig.integration.json",
    "test:integration": "npm run build:integration && node out/tests/integration/runTests.js",
    "prepackage": "node -e \"require('fs').mkdirSync('releases', {recursive: true})\"",
    "package": "vsce package --no-dependencies -o releases/",
    "check-l10n": "npx tsx scripts/check-l10n.ts",
    "release": "tsx scripts/release.ts",
    "release:patch": "tsx scripts/release.ts patch",
    "release:minor": "tsx scripts/release.ts minor",
    "release:major": "tsx scripts/release.ts major"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "~4.0.18",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^9.2.1",
    "esbuild": "^0.19.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "glob": "^13.0.6",
    "jsdom": "^28.1.0",
    "mocha": "^11.7.5",
    "ovsx": "^0.10.8",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.57.1",
    "vite": "^5.4.21",
    "vitest": "~4.0.18"
  },
  "dependencies": {
    "@tiptap/extension-placeholder": "^3.15.3",
    "@tiptap/pm": "^3.15.3",
    "@tiptap/react": "^3.15.3",
    "@tiptap/starter-kit": "^3.15.3",
    "@vscode/l10n": "^0.0.18",
    "clsx": "^2.1.1",
    "fractional-indexing": "^3.2.0",
    "lucide-react": "^0.562.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^2.2.0",
    "tiptap-markdown": "^0.9.0",
    "zustand": "^5.0.10"
  }
}
